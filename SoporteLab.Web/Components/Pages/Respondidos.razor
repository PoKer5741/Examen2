@page "/respondidos"
@using SoporteLab.Web.Models
@using SoporteLab.Web.Services
@inject TicketService TicketService

<PageTitle>Tickets Respondidos</PageTitle>

<h1>Historial de Tickets Respondidos</h1>
<p>Registro de fallas que ya fueron solucionadas y cerradas.</p>

<hr />

@if (tickets == null)
{
    <p><em>Cargando historial de soluciones...</em></p>
}
else if (tickets.Count == 0)
{
    <div class="alert alert-info">Aún no se ha respondido ningún ticket.</div>
}
else
{
    <div class="table-responsive table-soporte">
        <table class="table table-dark table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Título (Falla)</th>
                    <th>Categoría</th>
                    <th>Prioridad</th>
                    <th>Estado</th>
                    <th>Solicitante</th>
                    <th>Fecha de Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in tickets)
                {
                    <tr>
                        <td>@ticket.Id</td>
                        <td>@ticket.Titulo</td>
                        <td>@ticket.Categoria</td>
                        <td>
                            @if (ticket.Prioridad == "Alta")
                            {
                                <span class="badge badge-alta">@ticket.Prioridad</span>
                            }
                            else if (ticket.Prioridad == "Media")
                            {
                                <span class="badge badge-media">@ticket.Prioridad</span>
                            }
                            else if (ticket.Prioridad == "Baja")
                            {
                                <span class="badge badge-baja">@ticket.Prioridad</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@ticket.Prioridad</span>
                            }
                        </td>
                        <td><span class="badge bg-success">@ticket.Estado</span></td>
                        <td>@ticket.Solicitante</td>
                        <td>@ticket.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a href="/ticket/@ticket.Id" class="btn btn-sm btn-outline-info">Ver Detalle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Ticket>? tickets;

    protected override async Task OnInitializedAsync()
    {
        var todosLosTickets = await TicketService.GetTicketsAsync();
        // LINQ filtra y captura estrictamente los que dicen "Respondido"
        tickets = todosLosTickets?.Where(t => t.Estado == "Respondido").ToList();
    }
}