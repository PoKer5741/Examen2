@page "/crear"
@using SoporteLab.Web.Models
@using SoporteLab.Web.Services
@inject TicketService TicketService

<PageTitle>Nuevo Ticket</PageTitle>

<h1>Crear un Nuevo Ticket</h1>
<hr />

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="form-section">
            @if (mostrarExito)
            {
                <div class="alert alert-success mb-4 d-flex justify-content-between align-items-center">
                    <span>¡El ticket se envió correctamente!</span>
                    <button type="button" class="btn-close" @onclick="() => mostrarExito = false"></button>
                </div>
            }

            @if (mostrarError)
            {
                <div class="alert alert-danger mb-4">Error de conexión: No se pudo guardar en la base de datos. Verifica que la API esté corriendo.</div>
            }

            <EditForm Model="ticket" OnValidSubmit="GuardarTicket" FormName="FormularioTicket">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger mb-3" />

                <div class="mb-4">
                    <label class="form-label-soporte">Título (Falla):</label>
                    <InputText @bind-Value="ticket.Titulo" class="form-control" placeholder="Ej. El mouse no funciona" required />
                </div>

                <div class="mb-4">
                    <label class="form-label-soporte">Descripción:</label>
                    <InputTextArea @bind-Value="ticket.Descripcion" class="form-control" rows="4" required />
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label-soporte">Categoría:</label>
                        <InputSelect @bind-Value="ticket.Categoria" class="form-select" required>
                            <option value="">Seleccione una...</option>
                            <option value="Hardware">Hardware</option>
                            <option value="Software">Software</option>
                            <option value="Redes">Redes</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-soporte">Prioridad:</label>
                        <InputSelect @bind-Value="ticket.Prioridad" class="form-select" required>
                            <option value="">Seleccione una...</option>
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label-soporte">Solicitante:</label>
                    <InputText @bind-Value="ticket.Solicitante" class="form-control" required />
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-soporte-guardar me-md-2">Guardar Ticket</button>
                    <a href="/" class="btn btn-soporte-cancelar">Volver al Inicio</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private Ticket ticket { get; set; } = new();

    private bool mostrarError = false;
    private bool mostrarExito = false;

    private async Task GuardarTicket()
    {
        mostrarError = false;
        mostrarExito = false;
        
        ticket.FechaRegistro = DateTime.Now;
        ticket.Estado = "Nuevo";  

        var exito = await TicketService.CreateTicketAsync(ticket);
        
        if (exito)
        {
            mostrarExito = true;
            ticket = new();  
        }
        else
        {
            mostrarError = true; 
        }
    }
}