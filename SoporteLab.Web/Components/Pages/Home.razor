@page "/"
@rendermode InteractiveServer
@using SoporteLab.Web.Models
@using SoporteLab.Web.Services
@inject TicketService TicketService
@inject NavigationManager NavigationManager

<PageTitle>Tickets Pendientes</PageTitle>

<h1>Sistema de Soporte - Pendientes</h1>
<p>Lista de fallas registradas que requieren atención inmediata.</p>

<hr />

@if (tickets == null)
{
    <p><em>Cargando tickets pendientes...</em></p>
}
else if (tickets.Count == 0)
{
    <div class="alert alert-info">¡Felicidades! No hay tickets pendientes en el sistema.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <input type="text" class="form-control bg-dark text-white border-secondary" 
                   placeholder="Buscar por ID, título o solicitante..." 
                   @bind="TextoBusqueda" @bind:event="oninput" />
        </div>
    </div>

    <div class="table-responsive table-soporte">
        <table class="table table-dark table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Título (Falla)</th>
                    <th>Categoría</th>
                    <th>Prioridad</th>
                    <th>Estado</th>
                    <th>Solicitante</th>
                    <th>Fecha de Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in ticketsFiltrados!)
                {
                    <tr>
                        <td>@ticket.Id</td>
                        <td>@ticket.Titulo</td>
                        <td>@ticket.Categoria</td>
                        <td>
                            @if (ticket.Prioridad == "Alta")
                            {
                                <span class="badge badge-alta">@ticket.Prioridad</span>
                            }
                            else if (ticket.Prioridad == "Media")
                            {
                                <span class="badge badge-media">@ticket.Prioridad</span>
                            }
                            else if (ticket.Prioridad == "Baja")
                            {
                                <span class="badge badge-baja">@ticket.Prioridad</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@ticket.Prioridad</span>
                            }
                        </td>
                        <td>
                            @if (ticket.Estado == "Nuevo")
                            {
                                <span class="badge bg-danger">Nuevo</span>
                            }
                            else if (ticket.Estado == "Abierto")
                            {
                                <span class="badge bg-info">Abierto</span>
                            }
                            else if (ticket.Estado == "En proceso")
                            {
                                <span class="badge bg-warning text-dark">En proceso</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@ticket.Estado</span>
                            }
                        </td>
                        <td>@ticket.Solicitante</td>
                        <td>@ticket.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="btn-group gap-1">
                                <button @onclick="() => IrAVerTicket(ticket)" class="btn btn-sm btn-outline-info">Ver</button>
                                <button @onclick="() => MarcarComoRespondido(ticket)" class="btn btn-sm btn-success">Respondido</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (ticketsFiltrados.Count == 0)
        {
            <div class="alert alert-warning mt-3">No se encontraron tickets que coincidan con tu búsqueda.</div>
        }
    </div>
}

@code {
    private List<Ticket>? tickets;
    private List<Ticket>? ticketsFiltrados = new();

    private string _textoBusqueda = "";
    private string TextoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            _textoBusqueda = value;
            AplicarFiltro();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarTicketsPendientes();
    }

    private async Task CargarTicketsPendientes()
    {
        var todosLosTickets = await TicketService.GetTicketsAsync();
        tickets = todosLosTickets?.Where(t => t.Estado != "Respondido").ToList();
        AplicarFiltro(); 
    }

    private void AplicarFiltro()
    {
        if (string.IsNullOrWhiteSpace(_textoBusqueda))
        {
            ticketsFiltrados = tickets?
                .OrderBy(t => t.Prioridad == "Alta" ? 1 : t.Prioridad == "Media" ? 2 : t.Prioridad == "Baja" ? 3 : 4)
                .ToList(); 
        }
        else
        {
            ticketsFiltrados = tickets?.Where(t => 
                t.Id.ToString().Contains(_textoBusqueda) ||
                (t.Titulo != null && t.Titulo.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (t.Solicitante != null && t.Solicitante.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase))
            )
            .OrderBy(t => t.Prioridad == "Alta" ? 1 : t.Prioridad == "Media" ? 2 : t.Prioridad == "Baja" ? 3 : 4)
            .ToList();
        }
    }

    // LÓGICA DE CONTROL DE ESTADO AL HACER CLIC EN VER
    private async Task IrAVerTicket(Ticket t)
    {
        if (t.Estado == "Nuevo")
        {
            t.Estado = "Abierto";
            await TicketService.UpdateTicketAsync(t);
        }
        NavigationManager.NavigateTo($"/ticket/{t.Id}");
    }

    private async Task MarcarComoRespondido(Ticket ticketModificar)
    {
        ticketModificar.Estado = "Respondido";
        var exito = await TicketService.UpdateTicketAsync(ticketModificar);
        if (exito)
        {
            await CargarTicketsPendientes();
            StateHasChanged(); 
        }
    }
}