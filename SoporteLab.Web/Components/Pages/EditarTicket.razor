@page "/editar/{Id:int}"
@rendermode InteractiveServer
@using SoporteLab.Web.Models
@using SoporteLab.Web.Services
@inject TicketService TicketService
@inject NavigationManager NavigationManager

<PageTitle>Editar Ticket</PageTitle>

<h1>Editar Ticket #@Id</h1>
<p>Modifica los detalles, prioridad o estado del reporte.</p>
<hr />

@if (ticket == null)
{
    <p><em>Cargando datos del ticket...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="form-section">
                @if (mostrarError)
                {
                    <div class="alert alert-danger mb-4">Error al actualizar. Verifica que la API esté corriendo y conectada.</div>
                }

                <EditForm Model="ticket" OnValidSubmit="ActualizarTicket" FormName="FormularioEditar">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="mb-4">
                        <label class="form-label-soporte text-white">Título (Falla):</label>
                        <InputText @bind-Value="ticket.Titulo" class="form-control" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label-soporte text-white">Descripción:</label>
                        <InputTextArea @bind-Value="ticket.Descripcion" class="form-control" rows="4" required />
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label-soporte text-white">Categoría:</label>
                            <InputSelect @bind-Value="ticket.Categoria" class="form-select" required>
                                <option value="Hardware">Hardware</option>
                                <option value="Software">Software</option>
                                <option value="Redes">Redes</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-soporte text-white">Prioridad:</label>
                            <InputSelect @bind-Value="ticket.Prioridad" class="form-select" required>
                                <option value="Baja">Baja</option>
                                <option value="Media">Media</option>
                                <option value="Alta">Alta</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-soporte text-white">Estado:</label>
                            <InputSelect @bind-Value="ticket.Estado" class="form-select" required>
                                <option value="Abierto">Abierto</option>
                                <option value="En proceso">En proceso</option>
                                <option value="Respondido">Respondido</option>
                                <option value="Cerrado">Cerrado</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-soporte text-white">Solicitante (Solo lectura):</label>
                        <input type="text" value="@ticket.Solicitante" class="form-control bg-secondary text-white border-0" disabled />
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <button type="submit" class="btn btn-soporte-guardar me-md-2">Guardar Cambios</button>
                        <a href="/ticket/@ticket.Id" class="btn btn-soporte-cancelar">Cancelar</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Ticket? ticket;
    private bool mostrarError = false;

    protected override async Task OnInitializedAsync()
    {
        // Traemos los datos actuales desde la API usando el ID
        ticket = await TicketService.GetTicketByIdAsync(Id);
    }

    private async Task ActualizarTicket()
    {
        mostrarError = false;
        if (ticket != null)
        {
            // Mandamos los datos modificados al método PUT de la API
            var exito = await TicketService.UpdateTicketAsync(ticket);
            if (exito)
            {
                // Si todo sale bien, lo devolvemos a la pantalla de detalle para ver los cambios
                NavigationManager.NavigateTo($"/ticket/{ticket.Id}");
            }
            else
            {
                mostrarError = true;
            }
        }
    }
}