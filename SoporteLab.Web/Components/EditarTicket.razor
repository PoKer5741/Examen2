@page "/editar/{Id:int}"
@using SoporteLab.Web.Models
@using SoporteLab.Web.Services
@inject TicketService TicketService
@inject NavigationManager NavigationManager

<PageTitle>Editar Ticket</PageTitle>

<h1>Editar Ticket #@Id</h1>
<hr />

@if (ticket == null)
{
    <p><em>Cargando datos del ticket...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="form-section">
                @if (mostrarError)
                {
                    <div class="alert alert-danger">Error: No se pudo guardar. Verifica que la API esté encendida.</div>
                }

                <EditForm Model="ticket" OnValidSubmit="ActualizarTicket" FormName="FormularioEditar">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label class="form-label-soporte">Título (Falla):</label>
                        <InputText @bind-Value="ticket.Titulo" class="form-control" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label-soporte">Descripción:</label>
                        <InputTextArea @bind-Value="ticket.Descripcion" class="form-control" rows="4" required />
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label-soporte">Categoría:</label>
                            <InputSelect @bind-Value="ticket.Categoria" class="form-select" required>
                                <option value="Hardware">Hardware</option>
                                <option value="Software">Software</option>
                                <option value="Redes">Redes</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-soporte">Prioridad:</label>
                            <InputSelect @bind-Value="ticket.Prioridad" class="form-select" required>
                                <option value="Baja">Baja</option>
                                <option value="Media">Media</option>
                                <option value="Alta">Alta</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-soporte">Estado:</label>
                            <InputSelect @bind-Value="ticket.Estado" class="form-select" required>
                                <option value="Abierto">Abierto</option>
                                <option value="En Progreso">En Progreso</option>
                                <option value="Cerrado">Cerrado</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-soporte">Solicitante:</label>
                        <InputText @bind-Value="ticket.Solicitante" class="form-control" required />
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-soporte-guardar me-md-2">Guardar Cambios</button>
                        <a href="/" class="btn btn-soporte-cancelar">Cancelar</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [SupplyParameterFromForm]
    private Ticket? ticket { get; set; }

    private bool mostrarError = false;

    protected override async Task OnInitializedAsync()
    {
        // Traemos los datos originales del ticket al abrir la página
        ticket ??= await TicketService.GetTicketByIdAsync(Id);
    }

    private async Task ActualizarTicket()
    {
        if (ticket != null)
        {
            var exito = await TicketService.UpdateTicketAsync(ticket);
            if (exito)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                mostrarError = true; // Mostramos error si la API está apagada o falla
            }
        }
    }
}